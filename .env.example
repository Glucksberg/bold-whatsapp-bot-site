# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# WhatsApp Cloud API / Meta
WHATSAPP_VERIFY_TOKEN=change-me-verify-token
WHATSAPP_ACCESS_TOKEN=change-me-access-token
WHATSAPP_PHONE_NUMBER_ID=change-me-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=change-me-waba-id
WHATSAPP_APP_ID=change-me-app-id
WHATSAPP_APP_SECRET=change-me-app-secret
WHATSAPP_API_VERSION=v23.0

# Optional webhook security / validation
META_WEBHOOK_SIGNATURE_HEADER=x-hub-signature-256

# AI
OPENAI_API_KEY=change-me-openai-api-key
OPENAI_MODEL=openai-codex/gpt-5.4

# Routing / internal notifications
INTERNAL_NOTIFY_CHANNEL=telegram:bold-hq
INTERNAL_NOTIFY_ENABLED=false

# Storage
DEMANDS_STORAGE=local-json
DEMANDS_JSON_PATH=./data/demands.json
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Business behavior
BUSINESS_NAME=Bold
DEFAULT_TIMEZONE=America/Cuiaba
HANDOFF_REQUIRED=true
DEFAULT_OWNER=Pedro

# Classification / triage
TRIAGE_MAX_QUESTIONS=5
ALLOW_AUDIO_TRANSCRIPTION=false
ALLOW_IMAGE_CONTEXT=false
